{
  "manifest_version": 3,
  "name": "ESEA Team Stats",
  "version": "1.0.0",
  "description": "Shows aggregated per-player stats for ESEA league teams on FACEIT match pages.",
  "host_permissions": ["https://open.faceit.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.faceit.com/*/cs2/room/*"],
      "js": ["api.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
